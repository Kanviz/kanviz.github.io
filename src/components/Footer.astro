---
import { footerLinks, footerSocials } from '../data/footer';
import Icon from './Icon.astro';
---

<footer class="bg-slate-900 text-slate-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand Column -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-lg">
            KV
          </div>
          <span class="text-2xl font-bold text-white">Kanviz</span>
        </a>
        <p class="text-slate-400 leading-relaxed">
          Empowering businesses with data-driven insights through innovative visualization solutions and strategic consulting.
        </p>
        <div class="flex gap-4 pt-2">
          {footerSocials.map((social) => (
            <a
              key={social.platform}
              href={social.url}
              class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:bg-blue-600 hover:text-white transition-all duration-300"
              aria-label={social.platform}
            >
              <Icon name={social.icon} size={20} />
            </a>
          ))}
        </div>
      </div>

      <!-- Links Columns -->
      {footerLinks.map((column) => (
        <div key={column.title}>
          <h3 class="text-white font-semibold mb-4">{column.title}</h3>
          <ul class="space-y-2">
            {column.items.map((item) => (
              <li key={item.label}>
                <a
                  href={item.href}
                  class="text-slate-400 hover:text-blue-400 transition-colors duration-200 flex items-center gap-2 group"
                >
                  <Icon name="chevron-right" size={16} class="opacity-0 group-hover:opacity-100 transition-opacity duration-200" />
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-slate-800 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-sm">
        &copy; {new Date().getFullYear()} Kanviz. All rights reserved.
      </p>
      <p class="text-slate-500 text-sm">
        Designed with precision &bull; Built for growth
      </p>
    </div>
  </div>
</footer>
