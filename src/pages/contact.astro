---
import Layout from '../layouts/Layout.astro';
import { contactInfo } from '../data/contact';
import Section from '../components/Section.astro';
import Icon from '../components/Icon.astro';

interface FormState {
  name: string;
  email: string;
  message: string;
}

const initialState: FormState = {
  name: '',
  email: '',
  message: '',
};

let formState = initialState;
let submissionStatus: 'idle' | 'submitting' | 'success' | 'error' = 'idle';
---

<Layout title="Contact Us" description="Get in touch with Kanviz for your data visualization and business intelligence needs.">
  {/* Hero Section */}
  <Section bg="gradient" padding="lg">
    <div class="text-center max-w-3xl mx-auto space-y-6">
      <h1 class="text-5xl md:text-6xl font-bold text-white">Contact Us</h1>
      <p class="text-xl text-slate-200 leading-relaxed">
        Have a project in mind? We'd love to hear from you. Send us a message and we'll respond as soon as possible.
      </p>
    </div>
  </Section>

  {/* Contact Section */}
  <Section bg="light" padding="lg">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      {/* Contact Information */}
      <div class="space-y-8">
        <div class="space-y-4">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Get in Touch</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Whether you have a question about our services or want to discuss a potential project, our team is ready to help.
          </p>
        </div>

        <div class="space-y-6">
          <div class="flex items-start gap-4 p-6 bg-white rounded-2xl shadow-sm border border-slate-100">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 flex-shrink-0">
              <Icon name="mail" size={24} />
            </div>
            <div>
              <h3 class="text-lg font-semibold text-slate-900 mb-1">Email Us</h3>
              <a href={`mailto:${contactInfo.email}`} class="text-blue-600 hover:text-blue-700 transition-colors">
                {contactInfo.email}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4 p-6 bg-white rounded-2xl shadow-sm border border-slate-100">
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-purple-600 flex-shrink-0">
              <Icon name="phone" size={24} />
            </div>
            <div>
              <h3 class="text-lg font-semibold text-slate-900 mb-1">Call Us</h3>
              <a href={`tel:${contactInfo.phone}`} class="text-blue-600 hover:text-blue-700 transition-colors">
                {contactInfo.phone}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4 p-6 bg-white rounded-2xl shadow-sm border border-slate-100">
            <div class="w-12 h-12 bg-pink-100 rounded-xl flex items-center justify-center text-pink-600 flex-shrink-0">
              <Icon name="map-pin" size={24} />
            </div>
            <div>
              <h3 class="text-lg font-semibold text-slate-900 mb-1">Visit Us</h3>
              <p class="text-slate-600 whitespace-pre-line">{contactInfo.address}</p>
            </div>
          </div>
        </div>

        {/* Social Links */}
        <div class="pt-8">
          <h3 class="text-lg font-semibold text-slate-900 mb-4">Follow Us</h3>
          <div class="flex gap-4">
            {contactInfo.socials.map((social) => (
              <a
                key={social.platform}
                href={social.url}
                class="w-12 h-12 bg-slate-100 rounded-lg flex items-center justify-center text-slate-600 hover:bg-blue-600 hover:text-white transition-all duration-300"
                aria-label={social.platform}
              >
                <Icon name={social.icon} size={20} />
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* Contact Form */}
      <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-8 md:p-10">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Send us a Message</h2>

        {submissionStatus === 'success' ? (
          <div class="text-center py-12 space-y-4">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center text-green-600 mx-auto">
              <Icon name="check" size={40} />
            </div>
            <h3 class="text-2xl font-bold text-slate-900">Message Sent!</h3>
            <p class="text-slate-600">Thank you for reaching out. We'll get back to you within 24 hours.</p>
            <button
              onclick={() => {
                formState = initialState;
                submissionStatus = 'idle';
              }}
              class="mt-6 px-6 py-3 bg-slate-900 text-white rounded-lg font-medium hover:bg-blue-600 transition-colors"
            >
              Send Another Message
            </button>
          </div>
        ) : (
          <form
            class="space-y-6"
            onsubmit={(e) => {
              e.preventDefault();
              submissionStatus = 'submitting';
              // Simulate form submission
              setTimeout(() => {
                submissionStatus = 'success';
                formState = initialState;
              }, 1500);
            }}
          >
            <div class="space-y-2">
              <label for="name" class="text-sm font-medium text-slate-700">Full Name</label>
              <input
                type="text"
                id="name"
                required
                bind:value={formState.name}
                placeholder="John Doe"
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all"
              />
            </div>

            <div class="space-y-2">
              <label for="email" class="text-sm font-medium text-slate-700">Email Address</label>
              <input
                type="email"
                id="email"
                required
                bind:value={formState.email}
                placeholder="john@example.com"
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all"
              />
            </div>

            <div class="space-y-2">
              <label for="message" class="text-sm font-medium text-slate-700">Message</label>
              <textarea
                id="message"
                required
                rows={5}
                bind:value={formState.message}
                placeholder="How can we help you?"
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              disabled={submissionStatus === 'submitting'}
              class="w-full py-4 px-6 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg font-bold text-lg hover:shadow-lg hover:shadow-blue-500/30 transform hover:-translate-y-0.5 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
            >
              {submissionStatus === 'submitting' ? (
                <>
                  <span class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                  Sending...
                </>
              ) : (
                <>
                  Send Message
                  <Icon name="send" size={20} />
                </>
              )}
            </button>
          </form>
        )}
      </div>
    </div>
  </Section>

  {/* Map Section */}
  <Section bg="white" padding="lg">
    <div class="rounded-3xl overflow-hidden shadow-lg border border-slate-100">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3151.835434509371!2d-122.4194156846937!3d37.7749292797517!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80859a6d00690021%3A0x34e8c3d82b22d2b3!2sSan%20Francisco%2C%20CA!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
        width="100%"
        height="400"
        style="border:0; display:block;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Google Maps"
      ></iframe>
    </div>
  </Section>
</Layout>

<style>
  .check {
    display: inline-block;
  }
</style>
