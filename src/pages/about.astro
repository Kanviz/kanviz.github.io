---
import Layout from '../layouts/Layout.astro';
import { team } from '../data/team';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';

const values = [
  {
    title: 'Excellence',
    description: 'We strive for perfection in every AI system we build and every solution we deliver.',
    icon: 'target',
  },
  {
    title: 'Innovation',
    description: 'We embrace new technologies and creative approaches to solve complex AI challenges.',
    icon: 'lightbulb',
  },
  {
    title: 'Collaboration',
    description: 'We work closely with our clients to ensure their AI needs are fully understood and met.',
    icon: 'users',
  },
  {
    title: 'Integrity',
    description: 'We maintain the highest standards of ethics and transparency in all our AI deployments.',
    icon: 'shield',
  },
];
---

<Layout title="About Us" description="Learn more about Kanviz, our mission, values, and the team behind our success.">
  {/* Hero Section */}
  <Section bg="gradient" padding="lg">
    <div class="text-center max-w-3xl mx-auto space-y-6">
      <h1 class="text-5xl md:text-6xl font-bold text-white">About Kanviz</h1>
      <p class="text-xl text-slate-200 leading-relaxed">
        We are a premier AI company helping organizations unlock the power of their data through intelligent vision systems, language models, and autonomous agents.
      </p>
    </div>
  </Section>

  {/* Our Story */}
  <Section bg="light" padding="lg">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="relative order-2 lg:order-1">
        <div class="absolute -inset-4 bg-gradient-to-r from-blue-500 to-purple-600 rounded-3xl opacity-20 blur-2xl"></div>
        <div class="relative bg-white rounded-3xl overflow-hidden shadow-2xl border border-slate-100">
          <div class="w-full h-64 md:h-96 bg-gradient-to-br from-blue-500 via-purple-500 to-pink-500 flex items-center justify-center">
            <svg class="w-32 h-32 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="order-1 lg:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Our Story</h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          Founded in 2026, Kanviz began as a small team of AI enthusiasts with a big vision: to teach machines to see, observe, and understand. What started as a boutique consulting firm has grown into a leading provider of AI solutions serving clients across industries.
        </p>
        <p class="text-lg text-slate-600 leading-relaxed">
          Our journey has been defined by one constant: our commitment to helping organizations turn their data into actionable intelligence. We believe that great AI isn't just about algorithms—it's about building systems that see, reason, and act with purpose.
        </p>
        <p class="text-lg text-slate-600 leading-relaxed">
          Our team of AI researchers, engineers, and consultants work together to create solutions that not only meet but exceed expectations.
        </p>
      </div>
    </div>
  </Section>

  {/* Our Values */}
  <Section bg="dark" padding="lg">
    <div class="text-center max-w-2xl mx-auto mb-16 space-y-4">
      <h2 class="text-3xl md:text-4xl font-bold text-white">Our Core Values</h2>
      <p class="text-lg text-slate-300">The principles that guide everything we do</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map((value, index) => (
        <div key={index} class="bg-slate-800/50 backdrop-blur-sm rounded-2xl p-6 space-y-4 border border-slate-700 hover:border-blue-500 transition-colors duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center text-white">
            <Icon name={value.icon} size={24} />
          </div>
          <h3 class="text-xl font-bold text-white">{value.title}</h3>
          <p class="text-slate-300 leading-relaxed text-sm">{value.description}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* Team Section */}
  <Section bg="white" padding="lg">
    <div class="text-center max-w-2xl mx-auto mb-16 space-y-4">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Meet Our Leadership</h2>
      <p class="text-lg text-slate-600">The experienced team guiding our vision</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {team.map((member) => (
        <Card key={member.id} class="text-center p-8 space-y-6 group hover:shadow-xl transition-shadow duration-300">
          <div class="w-32 h-32 mx-auto rounded-full overflow-hidden border-4 border-white shadow-lg group-hover:border-blue-500 transition-colors duration-300">
            <img src={`/${member.name.toLowerCase().replace(' ', '-')}.jpeg`} alt={member.name} class="w-full h-full object-cover" />
          </div>
          <div class="space-y-4">
            <div>
              <h3 class="text-2xl font-bold text-slate-900">{member.name}</h3>
              <p class="text-blue-600 font-semibold text-lg">{member.role}</p>
            </div>
            <p class="text-slate-600 leading-relaxed">{member.bio}</p>
            {member.socials?.linkedin && (
              <a href={member.socials.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-[#0077b5] text-white rounded-lg font-medium hover:bg-[#0060a0] transition-colors duration-300">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.752s.784-1.752 1.75-1.752 1.75.79 1.75 1.752-.783 1.752-1.75 1.752zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
                LinkedIn Profile
              </a>
            )}
          </div>
        </Card>
      ))}
    </div>
  </Section>

  {/* CTA Section */}
  <Section bg="gradient" padding="lg">
    <div class="text-center max-w-3xl mx-auto space-y-8">
      <h2 class="text-4xl md:text-5xl font-bold text-white">Join Our Journey</h2>
      <p class="text-xl text-slate-200 leading-relaxed">
        We're always looking for talented individuals who share our passion for AI and innovation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-4 bg-white text-blue-900 rounded-xl font-bold text-lg hover:bg-slate-50 transition-colors duration-300 shadow-lg shadow-blue-900/20">
          View Open Positions
        </a>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .check {
    display: inline-block;
  }
</style>
